# Backend server port (Render provides this automatically in production)
PORT=4000

# Comma-separated list of allowed CORS origins.
# For local development, include your frontend dev server.
# For production, set this to your Netlify site URL(s), e.g.:
# CORS_ALLOWED_ORIGINS=https://your-site.netlify.app,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional model/debug settings
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=facebook/bart-large-mnli
CLASSIFICATION_DEBUG=false
